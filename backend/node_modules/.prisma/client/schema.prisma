// ============================================================
// Meramot marketplace schema (customer-focused iteration)
// PostgreSQL + Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  DELIVERY
}

enum VendorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ShopCategory {
  COURIER_PICKUP
  IN_SHOP_REPAIR
  SPARE_PARTS
}

enum RequestMode {
  CHECKUP_ONLY
  DIRECT_REPAIR
  CHECKUP_AND_REPAIR
}

enum RequestStatus {
  DRAFT
  PENDING
  BIDDING
  ASSIGNED
  PICKUP_SCHEDULED
  PICKED_UP
  AT_SHOP
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  RETURN_SCHEDULED
  RETURNING
  COMPLETED
  CANCELLED
  REJECTED
}

enum BidStatus {
  ACTIVE
  ACCEPTED
  DECLINED
  EXPIRED
}

enum RepairJobStatus {
  CREATED
  PICKUP_SCHEDULED
  PICKED_UP
  AT_SHOP
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  READY_TO_RETURN
  RETURNING
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  REGULAR
  EXPRESS
}

enum DeliveryDirection {
  TO_SHOP
  TO_CUSTOMER
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  BKASH
  NAGAD
  CARD
  CASH
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum HomeSectionType {
  HERO_OFFER
  PROMO_BANNER
  FEATURED_SHOPS
  POPULAR_CATEGORY
  RECENTLY_VIEWED
}

model User {
  id              String     @id @default(cuid())
  username        String     @unique
  email           String     @unique
  passwordHash    String
  name            String?
  phone           String?
  avatarUrl       String?
  address         String?
  city            String?
  area            String?
  lat             Float?
  lng             Float?
  isEmailVerified Boolean    @default(false)
  status          UserStatus @default(ACTIVE)
  role            UserRole   @default(CUSTOMER)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  repairRequests     RepairRequest[]
  payments           Payment[]
  ratings            Rating[]
  recentlyViewed     RecentlyViewed[]
  supportTickets     SupportTicket[]
  vendorApplications VendorApplication[]
  carts              Cart[]
}

model VendorApplication {
  id                    String                  @id @default(cuid())
  userId                String                  @unique
  ownerName             String
  businessEmail         String                  @unique
  phone                 String
  shopName              String
  tradeLicenseNo        String?
  address               String
  city                  String?
  area                  String?
  lat                   Float?
  lng                   Float?
  specialties           String[]
  courierPickup         Boolean                 @default(false)
  inShopRepair          Boolean                 @default(true)
  spareParts            Boolean                 @default(false)
  notes                 String?
  status                VendorApplicationStatus @default(PENDING)
  rejectionReason       String?
  rejectedAt            DateTime?
  rejectionVisibleUntil DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shop {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  description  String?
  logoUrl      String?
  bannerUrl    String?
  address      String
  city         String?
  area         String?
  lat          Float?
  lng          Float?
  phone        String?
  email        String?
  ratingAvg    Float          @default(0)
  reviewCount  Int            @default(0)
  priceLevel   Int            @default(2)
  isFeatured   Boolean        @default(false)
  isActive     Boolean        @default(true)
  hasVoucher   Boolean        @default(false)
  freeDelivery Boolean        @default(false)
  hasDeals     Boolean        @default(false)
  categories   ShopCategory[]
  specialties  String[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  bids       Bid[]
  ratings    Rating[]
  repairJobs RepairJob[]
  carts      Cart[]
}

model RepairRequest {
  id                String        @id @default(cuid())
  userId            String
  title             String
  description       String?
  deviceType        String
  brand             String?
  model             String?
  issueCategory     String?
  problem           String
  imageUrls         String[]
  mode              RequestMode
  status            RequestStatus @default(PENDING)
  preferredPickup   Boolean       @default(false)
  deliveryType      DeliveryType?
  checkupFee        Float?
  quotedFinalAmount Float?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bids      Bid[]
  payments  Payment[]
  repairJob RepairJob?

  @@index([userId])
  @@index([status])
  @@index([deviceType, brand, model])
}

model Bid {
  id              String    @id @default(cuid())
  repairRequestId String
  shopId          String
  partsCost       Float
  laborCost       Float
  totalCost       Float
  estimatedDays   Int?
  notes           String?
  status          BidStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  repairRequest RepairRequest @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairJob     RepairJob?

  @@unique([repairRequestId, shopId])
  @@index([repairRequestId])
  @@index([shopId])
}

model RepairJob {
  id                String          @id @default(cuid())
  repairRequestId   String          @unique
  shopId            String
  acceptedBidId     String?         @unique
  status            RepairJobStatus @default(CREATED)
  diagnosisNotes    String?
  finalQuotedAmount Float?
  customerApproved  Boolean?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  repairRequest RepairRequest @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  acceptedBid   Bid?          @relation(fields: [acceptedBidId], references: [id])
  deliveries    Delivery[]
  warranty      Warranty?

  @@index([shopId])
  @@index([status])
}

model Delivery {
  id            String            @id @default(cuid())
  repairJobId   String
  direction     DeliveryDirection
  type          DeliveryType      @default(REGULAR)
  status        DeliveryStatus    @default(PENDING)
  partnerName   String?
  trackingCode  String?
  riderName     String?
  riderPhone    String?
  pickupAddress String
  dropAddress   String
  distanceKm    Float?
  fee           Float?
  scheduledAt   DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  repairJob RepairJob @relation(fields: [repairJobId], references: [id], onDelete: Cascade)

  @@index([repairJobId])
  @@index([status])
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  repairRequestId String?
  amount          Float
  currency        String         @default("BDT")
  method          PaymentMethod?
  status          PaymentStatus  @default(PENDING)
  transactionRef  String?        @unique
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  repairRequest RepairRequest? @relation(fields: [repairRequestId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([repairRequestId])
  @@index([status])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  score     Int
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId])
}

model Warranty {
  id           String   @id @default(cuid())
  repairJobId  String   @unique
  title        String
  details      String?
  durationDays Int
  startsAt     DateTime
  endsAt       DateTime
  createdAt    DateTime @default(now())

  repairJob RepairJob @relation(fields: [repairJobId], references: [id], onDelete: Cascade)
}

model RecentlyViewed {
  id       String   @id @default(cuid())
  userId   String
  shopId   String
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt])
  @@index([shopId])
}

model SupportTicket {
  id              String              @id @default(cuid())
  userId          String
  repairRequestId String?
  subject         String
  message         String
  status          SupportTicketStatus @default(OPEN)
  priority        String?
  adminNotes      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model OfferBanner {
  id              String          @id @default(cuid())
  title           String
  subtitle        String?
  imageUrl        String?
  ctaLabel        String?
  ctaHref         String?
  backgroundColor String?
  isActive        Boolean         @default(true)
  position        Int             @default(0)
  sectionType     HomeSectionType @default(HERO_OFFER)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([isActive, position])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  shopId    String
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop  Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId, status])
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  serviceName String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(1)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}
