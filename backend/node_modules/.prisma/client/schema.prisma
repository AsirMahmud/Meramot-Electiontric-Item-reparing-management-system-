model Shop {
  id                   String         @id @default(cuid())
  vendorApplicationId  String?        @unique
  name                 String
  slug                 String         @unique
  description          String?
  logoUrl              String?
  bannerUrl            String?
  address              String
  city                 String?
  area                 String?
  lat                  Float?
  lng                  Float?
  phone                String?
  email                String?
  ratingAvg            Float          @default(0)
  reviewCount          Int            @default(0)
  priceLevel           Int            @default(2)
  isFeatured           Boolean        @default(false)
  isActive             Boolean        @default(true)
  hasVoucher           Boolean        @default(false)
  freeDelivery         Boolean        @default(false)
  hasDeals             Boolean        @default(false)
