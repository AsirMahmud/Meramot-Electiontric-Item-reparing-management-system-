# PostgreSQL — connection URI (user, password, host, port, database name)
# Example matches Prisma datasource provider "postgresql"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/meeramoot_electric_repair?schema=public"
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_PAYMENT_RESULT_PATH=/payment/result
BACKEND_BASE_URL=http://localhost:4000

# SSLCommerz credentials
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_LIVE=false
