# PostgreSQL — connection URI (user, password, host, port, database name)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/meeramoot_electric_repair?schema=public"
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# JWT Secrets
JWT_SECRET=dev-secret
JWT_SECRET_DELIVERY=dev-delivery-secret
JWT_SECRET_DELIVERY_ADMIN=dev-delivery-admin-secret

# Email Configuration
ENABLE_EMAIL_NOTIFICATIONS=false
RESEND_API_KEY=
EMAIL_FROM=

# SMTP (alternative to Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# AI Chat (Groq)
ENABLE_AI_CHAT=false
GROQ_API_KEY=

# SSLCommerz credentials
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_LIVE=false

# Pusher (real-time chat)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
