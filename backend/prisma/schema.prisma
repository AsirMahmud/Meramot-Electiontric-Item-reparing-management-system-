generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String               @id @default(cuid())
  username                   String               @unique
  email                      String               @unique
  passwordHash               String
  name                       String?
  phone                      String?
  avatarUrl                  String?
  address                    String?
  city                       String?
  area                       String?
  lat                        Float?
  lng                        Float?
  isEmailVerified            Boolean              @default(false)
  status                     UserStatus           @default(ACTIVE)
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  role                       UserRole             @default(CUSTOMER)
  carts                      Cart[]
  payments                   Payment[]
  moderationActions          Rating[]             @relation("RatingModerator")
  ratings                    Rating[]             @relation("RatingAuthor")
  recentlyViewed             RecentlyViewed[]
  repairRequests             RepairRequest[]
  riderProfile               RiderProfile?
  shopMemberships            ShopStaff[]
  assignedSupportTickets     SupportTicket[]      @relation("TicketAssignee")
  supportTickets             SupportTicket[]      @relation("TicketCreator")
  reviewedVendorApplications VendorApplication[]  @relation("VendorApplicationReviewer")
  reviewedVerifications      VerificationRecord[] @relation("VerificationReviewer")
  verificationRecords        VerificationRecord[] @relation("VerificationSubjectUser")
  openedDisputes             DisputeCase[]        @relation("DisputeOpener")
  disputesAgainst            DisputeCase[]        @relation("DisputeSubject")
  assignedDisputes           DisputeCase[]        @relation("DisputeAssignee")
  disputeNotes               DisputeNote[]
  vendorApplications         VendorApplication[]  @relation("VendorApplicant")
  supportMessages            SupportMessage[]
  refundsApproved            Refund[]             @relation("RefundApprover")
}

model VendorApplication {
  id                 String                  @id @default(cuid())
  ownerName          String
  businessEmail      String                  @unique
  phone              String
  shopName           String
  tradeLicenseNo     String?
  address            String
  city               String?
  area               String?
  lat                Float?
  lng                Float?
  specialties        String[]
  courierPickup      Boolean                 @default(false)
  inShopRepair       Boolean                 @default(true)
  spareParts         Boolean                 @default(false)
  notes              String?
  reviewNotes        String?
  status             VendorApplicationStatus @default(PENDING)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  reviewedAt         DateTime?
  reviewedByAdminId  String?
  shop               Shop?
  reviewedByAdmin    User?                   @relation("VendorApplicationReviewer", fields: [reviewedByAdminId], references: [id])
  applicantUserId    String?
  applicant          User?                   @relation("VendorApplicant", fields: [applicantUserId], references: [id])
  verificationRecord VerificationRecord?

  @@index([status])
  @@index([reviewedByAdminId])
  @@index([applicantUserId])
}

model Shop {
  id                   String               @id @default(cuid())
  name                 String
  slug                 String               @unique
  description          String?
  logoUrl              String?
  bannerUrl            String?
  address              String
  city                 String?
  area                 String?
  lat                  Float?
  lng                  Float?
  phone                String?
  email                String?
  ratingAvg            Float                @default(0)
  reviewCount          Int                  @default(0)
  priceLevel           Int                  @default(2)
  isFeatured           Boolean              @default(false)
  isActive             Boolean              @default(true)
  hasVoucher           Boolean              @default(false)
  freeDelivery         Boolean              @default(false)
  hasDeals             Boolean              @default(false)
  categories           ShopCategory[]
  specialties          String[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  acceptsDirectOrders  Boolean              @default(true)
  deliveryRadiusKm     Float?
  openingHoursText     String?
  supportsOnsiteRepair Boolean              @default(false)
  supportsPickup       Boolean              @default(false)
  vendorApplicationId  String?              @unique
  bids                 Bid[]
  carts                Cart[]
  invoices             Invoice[]
  ledgerEntries        LedgerEntry[]
  ratings              Rating[]
  recentlyViewed       RecentlyViewed[]
  repairJobs           RepairJob[]
  directRequests       RepairRequest[]      @relation("RequestedShopRequests")
  vendorApplication    VendorApplication?   @relation(fields: [vendorApplicationId], references: [id])
  services             ShopService[]
  staff                ShopStaff[]
  supportTickets       SupportTicket[]
  payouts              VendorPayout[]
  verificationRecords  VerificationRecord[]

  @@index([isActive, isFeatured])
  @@index([city, area])
}

model ShopStaff {
  id        String        @id @default(cuid())
  shopId    String
  userId    String
  role      ShopStaffRole @default(STAFF)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  shop      Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shopId, userId])
  @@index([userId])
}

model ShopService {
  id               String                 @id @default(cuid())
  shopId           String
  slug             String
  name             String
  shortDescription String?
  description      String?
  deviceType       String?
  issueCategory    String?
  pricingType      ShopServicePricingType @default(INSPECTION_REQUIRED)
  basePrice        Float?
  priceMax         Float?
  estimatedDaysMin Int?
  estimatedDaysMax Int?
  includesPickup   Boolean                @default(false)
  includesDelivery Boolean                @default(false)
  sortOrder        Int                    @default(0)
  isFeatured       Boolean                @default(false)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  invoiceLineItems InvoiceLineItem[]
  requestedIn      RepairRequest[]
  shop             Shop                   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, slug])
  @@index([shopId, isActive, sortOrder])
  @@index([deviceType, issueCategory])
}

model RepairRequest {
  id                 String            @id @default(cuid())
  userId             String
  title              String
  description        String?
  deviceType         String
  brand              String?
  model              String?
  issueCategory      String?
  problem            String
  imageUrls          String[]
  mode               RequestMode
  status             RequestStatus     @default(PENDING)
  preferredPickup    Boolean           @default(false)
  deliveryType       DeliveryType?
  checkupFee         Float?
  quotedFinalAmount  Float?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  contactPhone       String?
  dropoffAddress     String?
  pickupAddress      String?
  requestedServiceId String?
  requestedShopId    String?
  source             RequestSource     @default(MARKETPLACE)
  bids               Bid[]
  invoices           Invoice[]
  notifications      NotificationLog[]
  payments           Payment[]
  repairJob          RepairJob?
  requestedService   ShopService?      @relation(fields: [requestedServiceId], references: [id])
  requestedShop      Shop?             @relation("RequestedShopRequests", fields: [requestedShopId], references: [id])
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  supportTickets     SupportTicket[]
  disputeCases       DisputeCase[]

  @@index([userId])
  @@index([status])
  @@index([source, status])
  @@index([requestedShopId])
  @@index([requestedServiceId])
  @@index([deviceType, brand, model])
}

model Bid {
  id              String        @id @default(cuid())
  repairRequestId String
  shopId          String
  partsCost       Float
  laborCost       Float
  totalCost       Float
  estimatedDays   Int?
  notes           String?
  status          BidStatus     @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  repairRequest   RepairRequest @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  shop            Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairJob       RepairJob?

  @@unique([repairRequestId, shopId])
  @@index([repairRequestId])
  @@index([shopId])
}

model RepairJob {
  id                String          @id @default(cuid())
  repairRequestId   String          @unique
  shopId            String
  acceptedBidId     String?         @unique
  status            RepairJobStatus @default(CREATED)
  diagnosisNotes    String?
  finalQuotedAmount Float?
  customerApproved  Boolean?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deliveries        Delivery[]
  invoices          Invoice[]
  acceptedBid       Bid?            @relation(fields: [acceptedBidId], references: [id])
  repairRequest     RepairRequest   @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  shop              Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supportTickets    SupportTicket[]
  warranty          Warranty?

  @@index([shopId])
  @@index([status])
}

model RiderProfile {
  id                   String                        @id @default(cuid())
  userId               String                        @unique
  vehicleType          String?
  nidDocumentUrl       String?
  educationDocumentUrl String?
  cvDocumentUrl        String?
  status               DeliveryAgentStatus           @default(OFFLINE)
  isActive             Boolean                       @default(true)
  registrationStatus   DeliveryPartnerApprovalStatus @default(APPROVED)
  currentLat           Float?
  currentLng           Float?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  deliveries           Delivery[]
  coverageZones        RiderCoverage[]
  user                 User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutRecords        VendorPayout[]                @relation("DeliveryAgentPayouts")

  @@index([status, isActive])
  @@index([registrationStatus])
}

model CoverageZone {
  id         String          @id @default(cuid())
  name       String
  city       String?
  area       String?
  postalCode String?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deliveries Delivery[]
  riders     RiderCoverage[]

  @@index([city, area])
}

model RiderCoverage {
  id             String       @id @default(cuid())
  riderProfileId String
  coverageZoneId String
  createdAt      DateTime     @default(now())
  coverageZone   CoverageZone @relation(fields: [coverageZoneId], references: [id], onDelete: Cascade)
  riderProfile   RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)

  @@unique([riderProfileId, coverageZoneId])
}

model Delivery {
  id                 String                @id @default(cuid())
  repairJobId        String
  direction          DeliveryDirection
  type               DeliveryType          @default(REGULAR)
  status             DeliveryStatus        @default(PENDING)
  partnerName        String?
  trackingCode       String?
  riderName          String?
  riderPhone         String?
  pickupAddress      String
  dropAddress        String
  distanceKm         Float?
  fee                Float?
  scheduledAt        DateTime?
  pickedUpAt         DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  cancellationReason String?
  coverageZoneId     String?
  deliveryAgentId    String?
  dispatchedAt       DateTime?
  externalOrderId    String?
  coverageZone       CoverageZone?         @relation(fields: [coverageZoneId], references: [id])
  deliveryAgent      RiderProfile?         @relation(fields: [deliveryAgentId], references: [id])
  repairJob          RepairJob             @relation(fields: [repairJobId], references: [id], onDelete: Cascade)
  chatMessages       DeliveryChatMessage[]
  notifications      NotificationLog[]

  @@index([repairJobId])
  @@index([status])
  @@index([deliveryAgentId])
}

model DeliveryChatMessage {
  id              String   @id @default(cuid())
  deliveryId      String
  senderUserId    String
  senderRole      UserRole
  recipientUserId String
  message         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  delivery        Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, createdAt])
  @@index([senderUserId, recipientUserId, createdAt])
}

model VerificationRecord {
  id                  String                 @id @default(cuid())
  targetType          VerificationTargetType
  status              VerificationStatus     @default(PENDING)
  provider            VerificationProvider   @default(MANUAL)
  userId              String?
  vendorApplicationId String?                @unique
  shopId              String?
  reviewedByAdminId   String?
  subjectRef          String?
  providerReference   String?
  notes               String?
  requestedAt         DateTime               @default(now())
  resolvedAt          DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  reviewedByAdmin     User?                  @relation("VerificationReviewer", fields: [reviewedByAdminId], references: [id])
  shop                Shop?                  @relation(fields: [shopId], references: [id])
  user                User?                  @relation("VerificationSubjectUser", fields: [userId], references: [id])
  vendorApplication   VendorApplication?     @relation(fields: [vendorApplicationId], references: [id], onDelete: Cascade)

  @@index([status, provider])
  @@index([userId])
  @@index([shopId])
}

model Invoice {
  id               String            @id @default(cuid())
  repairRequestId  String?
  repairJobId      String?
  shopId           String?
  type             InvoiceType       @default(FINAL)
  status           InvoiceStatus     @default(DRAFT)
  invoiceNumber    String            @unique
  subtotalAmount   Float             @default(0)
  deliveryAmount   Float             @default(0)
  discountAmount   Float             @default(0)
  commissionAmount Float             @default(0)
  totalAmount      Float             @default(0)
  issuedAt         DateTime?
  dueAt            DateTime?
  paidAt           DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  repairJob        RepairJob?        @relation(fields: [repairJobId], references: [id])
  repairRequest    RepairRequest?    @relation(fields: [repairRequestId], references: [id])
  shop             Shop?             @relation(fields: [shopId], references: [id])
  lineItems        InvoiceLineItem[]
  ledgerEntries    LedgerEntry[]
  payments         Payment[]

  @@index([repairRequestId])
  @@index([repairJobId])
  @@index([shopId])
  @@index([status])
}

model InvoiceLineItem {
  id            String       @id @default(cuid())
  invoiceId     String
  shopServiceId String?
  title         String
  description   String?
  quantity      Int          @default(1)
  unitPrice     Float        @default(0)
  totalPrice    Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  invoice       Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shopService   ShopService? @relation(fields: [shopServiceId], references: [id])

  @@index([invoiceId])
  @@index([shopServiceId])
}

model Payment {
  id              String         @id @default(cuid())
  userId          String
  repairRequestId String?
  amount          Float
  currency        String         @default("BDT")
  method          PaymentMethod?
  status          PaymentStatus  @default(PENDING)
  transactionRef  String?        @unique
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  gatewayResponse String?
  invoiceId       String?
  escrowStatus    EscrowStatus   @default(NOT_APPLICABLE)
  ledgerEntries   LedgerEntry[]
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id])
  repairRequest   RepairRequest? @relation(fields: [repairRequestId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  disputeCases    DisputeCase[]
  refunds         Refund[]
  escrowLedgers   EscrowLedger[]

  @@index([userId])
  @@index([repairRequestId])
  @@index([invoiceId])
  @@index([status])
}

model LedgerEntry {
  id          String          @id @default(cuid())
  shopId      String?
  paymentId   String?
  invoiceId   String?
  payoutId    String?
  type        LedgerEntryType
  direction   LedgerDirection
  amount      Float
  currency    String          @default("BDT")
  description String?
  effectiveAt DateTime        @default(now())
  createdAt   DateTime        @default(now())
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id])
  payment     Payment?        @relation(fields: [paymentId], references: [id])
  payout      VendorPayout?   @relation(fields: [payoutId], references: [id])
  shop        Shop?           @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([payoutId])
  @@index([type, direction])
}

model VendorPayout {
  id             String        @id @default(cuid())
  shopId         String?
  riderProfileId String?
  amount         Float
  currency       String        @default("BDT")
  status         PayoutStatus  @default(PENDING)
  reference      String?       @unique
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ledgerEntries  LedgerEntry[]
  riderProfile   RiderProfile? @relation("DeliveryAgentPayouts", fields: [riderProfileId], references: [id])
  shop           Shop?         @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([riderProfileId])
  @@index([status])
}

model Rating {
  id             String    @id @default(cuid())
  userId         String
  shopId         String
  score          Int
  review         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isHidden       Boolean   @default(false)
  moderatedAt    DateTime?
  moderatedById  String?
  moderationNote String?
  moderatedBy    User?     @relation("RatingModerator", fields: [moderatedById], references: [id])
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user           User      @relation("RatingAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId])
  @@index([moderatedById])
}

model Warranty {
  id           String    @id @default(cuid())
  repairJobId  String    @unique
  title        String
  details      String?
  durationDays Int
  startsAt     DateTime
  endsAt       DateTime
  createdAt    DateTime  @default(now())
  repairJob    RepairJob @relation(fields: [repairJobId], references: [id], onDelete: Cascade)
}

model RecentlyViewed {
  id       String   @id @default(cuid())
  userId   String
  shopId   String
  viewedAt DateTime @default(now())
  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt])
  @@index([shopId])
}

model SupportTicket {
  id              String              @id @default(cuid())
  userId          String
  repairRequestId String?
  subject         String
  message         String
  status          SupportTicketStatus @default(OPEN)
  priority        String?
  adminNotes      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  assigneeAdminId String?
  repairJobId     String?
  shopId          String?
  assigneeAdmin   User?               @relation("TicketAssignee", fields: [assigneeAdminId], references: [id])
  repairJob       RepairJob?          @relation(fields: [repairJobId], references: [id])
  repairRequest   RepairRequest?      @relation(fields: [repairRequestId], references: [id])
  shop            Shop?               @relation(fields: [shopId], references: [id])
  user            User                @relation("TicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  disputeCases    DisputeCase[]
  messages        SupportMessage[]

  @@index([userId])
  @@index([shopId])
  @@index([repairRequestId])
  @@index([repairJobId])
  @@index([status])
}

model NotificationLog {
  id              String              @id @default(cuid())
  repairRequestId String?
  deliveryId      String?
  channel         NotificationChannel
  recipient       String
  subject         String?
  body            String
  provider        String?
  providerRef     String?
  status          NotificationStatus  @default(QUEUED)
  sentAt          DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  delivery        Delivery?           @relation(fields: [deliveryId], references: [id])
  repairRequest   RepairRequest?      @relation(fields: [repairRequestId], references: [id])

  @@index([repairRequestId])
  @@index([deliveryId])
  @@index([channel, status])
}

model OfferBanner {
  id              String          @id @default(cuid())
  title           String
  subtitle        String?
  imageUrl        String?
  ctaLabel        String?
  ctaHref         String?
  backgroundColor String?
  isActive        Boolean         @default(true)
  position        Int             @default(0)
  sectionType     HomeSectionType @default(HERO_OFFER)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([isActive, position])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  shopId    String
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([userId, status])
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  serviceName String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(1)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  DELIVERY
  DELIVERY_ADMIN
}

enum DeliveryPartnerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
  BANNED
}

enum VendorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
  MORE_INFO_REQUIRED
  SUSPENDED
}

enum ShopCategory {
  COURIER_PICKUP
  IN_SHOP_REPAIR
  SPARE_PARTS
}

enum ShopStaffRole {
  OWNER
  MANAGER
  STAFF
}

enum RequestMode {
  CHECKUP_ONLY
  DIRECT_REPAIR
  CHECKUP_AND_REPAIR
}

enum RequestSource {
  MARKETPLACE
  DIRECT_SERVICE
  DIRECT_CUSTOM_SHOP
}

enum RequestStatus {
  DRAFT
  PENDING
  BIDDING
  ASSIGNED
  PICKUP_SCHEDULED
  PICKED_UP
  AT_SHOP
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  RETURN_SCHEDULED
  RETURNING
  COMPLETED
  CANCELLED
  REJECTED
}

enum BidStatus {
  ACTIVE
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum RepairJobStatus {
  CREATED
  PICKUP_SCHEDULED
  PICKED_UP
  AT_SHOP
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  READY_TO_RETURN
  RETURNING
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  REGULAR
  EXPRESS
}

enum DeliveryDirection {
  TO_SHOP
  TO_CUSTOMER
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
  DISPATCHED
}

enum DeliveryAgentStatus {
  OFFLINE
  AVAILABLE
  BUSY
  SUSPENDED
}

enum ShopServicePricingType {
  FIXED
  STARTING_FROM
  INSPECTION_REQUIRED
}

enum VerificationTargetType {
  USER
  VENDOR_APPLICATION
  SHOP
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  REJECTED
}

enum VerificationProvider {
  MANUAL
  PORICHOY
  TRADE_LICENSE
  OTHER
}

enum PaymentMethod {
  BKASH
  NAGAD
  CARD
  CASH
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  AUTHORIZED
}

enum InvoiceType {
  CHECKUP
  REPAIR
  DELIVERY
  FINAL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum EscrowStatus {
  HELD
  RELEASED
  PARTIALLY_REFUNDED
  NOT_APPLICABLE
}

enum LedgerEntryType {
  CUSTOMER_PAYMENT
  PLATFORM_COMMISSION
  VENDOR_EARNING
  VENDOR_PAYOUT
  DELIVERY_FEE
  DELIVERY_PAYOUT
  REFUND
  ADJUSTMENT
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

enum HomeSectionType {
  HERO_OFFER
  PROMO_BANNER
  FEATURED_SHOPS
  POPULAR_CATEGORY
  RECENTLY_VIEWED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum DisputeStatus {
  OPEN
  INVESTIGATING
  WAITING_EVIDENCE
  RESOLVED
  REFUNDED
  PARTIALLY_REFUNDED
  REJECTED
  CLOSED
}

model DisputeCase {
  id               String        @id @default(cuid())
  openedById       String
  againstId        String?
  paymentId        String?
  repairRequestId  String?
  supportTicketId  String?
  assignedAdminId  String?
  status           DisputeStatus @default(OPEN)
  resolution       String?
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  openedBy      User           @relation("DisputeOpener", fields: [openedById], references: [id])
  against       User?          @relation("DisputeSubject", fields: [againstId], references: [id])
  payment       Payment?       @relation(fields: [paymentId], references: [id])
  repairRequest RepairRequest? @relation(fields: [repairRequestId], references: [id])
  supportTicket SupportTicket? @relation(fields: [supportTicketId], references: [id])
  assignedAdmin User?          @relation("DisputeAssignee", fields: [assignedAdminId], references: [id])
  notes         DisputeNote[]
  refunds       Refund[]
  escrowLedgers EscrowLedger[]
}

model DisputeNote {
  id            String      @id @default(cuid())
  disputeCaseId String
  authorId      String
  note          String
  isInternal    Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  disputeCase DisputeCase @relation(fields: [disputeCaseId], references: [id], onDelete: Cascade)
  author      User        @relation(fields: [authorId], references: [id])
}

model Refund {
  id            String   @id @default(cuid())
  paymentId     String
  disputeCaseId String?
  approvedById  String?
  amount        Decimal  @db.Decimal(10, 2)
  status        String   @default("PENDING")
  reason        String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payment     Payment      @relation(fields: [paymentId], references: [id])
  disputeCase DisputeCase? @relation(fields: [disputeCaseId], references: [id])
  approvedBy  User?        @relation("RefundApprover", fields: [approvedById], references: [id])
}

model EscrowLedger {
  id              String   @id @default(cuid())
  paymentId       String?
  disputeCaseId   String?
  amount          Float
  action          String
  note            String?
  createdAt       DateTime @default(now())

  payment     Payment?     @relation(fields: [paymentId], references: [id])
  disputeCase DisputeCase? @relation(fields: [disputeCaseId], references: [id])
}

model SupportMessage {
  id             String   @id @default(cuid())
  ticketId       String
  authorId       String
  senderType     String
  message        String
  attachmentUrls String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
}
