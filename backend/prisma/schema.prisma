generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
  DELIVERY
  DELIVERY_ADMIN
}

enum DeliveryPartnerApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum VendorApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ShopCategory {
  COURIER_PICKUP
  IN_SHOP_REPAIR
  SPARE_PARTS
}

enum ShopStaffRole {
  OWNER
  MANAGER
  STAFF
}

enum RequestMode {
  CHECKUP_ONLY
  DIRECT_REPAIR
  CHECKUP_AND_REPAIR
}

enum RequestSource {
  MARKETPLACE
  DIRECT_SERVICE
  DIRECT_CUSTOM_SHOP
}

enum RequestStatus {
  DRAFT
  PENDING
  BIDDING
  ASSIGNED
  PICKUP_SCHEDULED
  PICKED_UP
  AT_SHOP
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  RETURN_SCHEDULED
  RETURNING
  COMPLETED
  CANCELLED
  REJECTED
}

enum BidStatus {
  ACTIVE
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum RepairJobStatus {
  CREATED
  PICKUP_SCHEDULED
  PICKED_UP
  AT_SHOP
  DIAGNOSING
  WAITING_APPROVAL
  REPAIRING
  READY_TO_RETURN
  RETURNING
  COMPLETED
  CANCELLED
}

enum DeliveryType {
  REGULAR
  EXPRESS
}

enum DeliveryDirection {
  TO_SHOP
  TO_CUSTOMER
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  DISPATCHED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum DeliveryAgentStatus {
  OFFLINE
  AVAILABLE
  BUSY
  SUSPENDED
}

enum ShopServicePricingType {
  FIXED
  STARTING_FROM
  INSPECTION_REQUIRED
}

enum VerificationTargetType {
  USER
  VENDOR_APPLICATION
  SHOP
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  REJECTED
}

enum VerificationProvider {
  MANUAL
  PORICHOY
  TRADE_LICENSE
  OTHER
}

enum PaymentMethod {
  BKASH
  NAGAD
  CARD
  CASH
  SSLCOMMERZ
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceType {
  CHECKUP
  REPAIR
  DELIVERY
  FINAL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum LedgerEntryType {
  CUSTOMER_PAYMENT
  PLATFORM_COMMISSION
  VENDOR_EARNING
  VENDOR_PAYOUT
  DELIVERY_FEE
  DELIVERY_PAYOUT
  REFUND
  ADJUSTMENT
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum HomeSectionType {
  HERO_OFFER
  PROMO_BANNER
  FEATURED_SHOPS
  POPULAR_CATEGORY
  RECENTLY_VIEWED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

model User {
  id              String      @id @default(cuid())
  username        String      @unique
  email           String      @unique
  passwordHash    String
  role            UserRole    @default(CUSTOMER)
  name            String?
  phone           String?
  avatarUrl       String?
  address         String?
  city            String?
  area            String?
  lat             Float?
  lng             Float?
  isEmailVerified Boolean     @default(false)
  status          UserStatus  @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  repairRequests             RepairRequest[]
  payments                   Payment[]
  ratings                    Rating[]              @relation("RatingAuthor")
  recentlyViewed             RecentlyViewed[]
  supportTickets             SupportTicket[]       @relation("TicketCreator")
  assignedSupportTickets     SupportTicket[]       @relation("TicketAssignee")
  moderationActions          Rating[]              @relation("RatingModerator")
  shopMemberships            ShopStaff[]
  verificationRecords        VerificationRecord[]  @relation("VerificationSubjectUser")
  reviewedVerifications      VerificationRecord[]  @relation("VerificationReviewer")
  reviewedVendorApplications VendorApplication[]   @relation("VendorApplicationReviewer")
  riderProfile               RiderProfile?
  carts                      Cart[]
  aiChatSessions AiChatSession[]
}

model VendorApplication {
  id                String                  @id @default(cuid())
  ownerName         String
  businessEmail     String                  @unique
  phone             String
  shopName          String
  tradeLicenseNo    String?
  address           String
  city              String?
  area              String?
  lat               Float?
  lng               Float?
  specialties       String[]
  courierPickup     Boolean                 @default(false)
  inShopRepair      Boolean                 @default(true)
  spareParts        Boolean                 @default(false)
  notes             String?
  status            VendorApplicationStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedAt        DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  reviewedByAdmin    User?                @relation("VendorApplicationReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  verificationRecord VerificationRecord?
  shop               Shop?

  @@index([status])
  @@index([reviewedByAdminId])
}

model Shop {
  id                   String         @id @default(cuid())
  vendorApplicationId  String?        @unique
  name                 String
  slug                 String         @unique
  description          String?
  logoUrl              String?
  bannerUrl            String?
  address              String
  city                 String?
  area                 String?
  lat                  Float?
  lng                  Float?
  phone                String?
  email                String?
  ratingAvg            Float          @default(0)
  reviewCount          Int            @default(0)
  priceLevel           Int            @default(2)
  isFeatured           Boolean        @default(false)
  isActive             Boolean        @default(true)
  hasVoucher           Boolean        @default(false)
  freeDelivery         Boolean        @default(false)
  hasDeals             Boolean        @default(false)
  acceptsDirectOrders  Boolean        @default(true)
  supportsPickup       Boolean        @default(false)
  supportsOnsiteRepair Boolean        @default(false)
  deliveryRadiusKm     Float?
  openingHoursText     String?
  categories           ShopCategory[]
  specialties          String[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  vendorApplication   VendorApplication?  @relation(fields: [vendorApplicationId], references: [id], onDelete: SetNull)
  bids                Bid[]
  ratings             Rating[]
  repairJobs          RepairJob[]
  services            ShopService[]
  directRequests      RepairRequest[]     @relation("RequestedShopRequests")
  recentlyViewed      RecentlyViewed[]
  staff               ShopStaff[]
  verificationRecords VerificationRecord[]
  invoices            Invoice[]
  payouts             VendorPayout[]
  ledgerEntries       LedgerEntry[]
  supportTickets      SupportTicket[]
  carts               Cart[]

  @@index([isActive, isFeatured])
  @@index([city, area])
}

model ShopStaff {
  id        String        @id @default(cuid())
  shopId    String
  userId    String
  role      ShopStaffRole @default(STAFF)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shopId, userId])
  @@index([userId])
}

model ShopService {
  id               String                 @id @default(cuid())
  shopId           String
  slug             String
  name             String
  shortDescription String?
  description      String?
  deviceType       String?
  issueCategory    String?
  pricingType      ShopServicePricingType @default(INSPECTION_REQUIRED)
  basePrice        Float?
  priceMax         Float?
  estimatedDaysMin Int?
  estimatedDaysMax Int?
  includesPickup   Boolean                @default(false)
  includesDelivery Boolean                @default(false)
  sortOrder        Int                    @default(0)
  isFeatured       Boolean                @default(false)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  requestedIn      RepairRequest[]
  invoiceLineItems InvoiceLineItem[]

  @@unique([shopId, slug])
  @@index([shopId, isActive, sortOrder])
  @@index([deviceType, issueCategory])
}

model RepairRequest {
  id                 String         @id @default(cuid())
  userId             String
  source             RequestSource  @default(MARKETPLACE)
  requestedShopId    String?
  requestedServiceId String?
  title              String
  description        String?
  deviceType         String
  brand              String?
  model              String?
  issueCategory      String?
  problem            String
  imageUrls          String[]
  mode               RequestMode
  status             RequestStatus  @default(PENDING)
  preferredPickup    Boolean        @default(false)
  deliveryType       DeliveryType?
  contactPhone       String?
  pickupAddress      String?
  dropoffAddress     String?
  checkupFee         Float?
  quotedFinalAmount  Float?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedShop    Shop?        @relation("RequestedShopRequests", fields: [requestedShopId], references: [id], onDelete: SetNull)
  requestedService ShopService? @relation(fields: [requestedServiceId], references: [id], onDelete: SetNull)
  bids             Bid[]
  payments         Payment[]
  repairJob        RepairJob?
  supportTickets   SupportTicket[]
  invoices         Invoice[]
  notifications    NotificationLog[]

  @@index([userId])
  @@index([status])
  @@index([source, status])
  @@index([requestedShopId])
  @@index([requestedServiceId])
  @@index([deviceType, brand, model])
}

model Bid {
  id              String    @id @default(cuid())
  repairRequestId String
  shopId          String
  partsCost       Float
  laborCost       Float
  totalCost       Float
  estimatedDays   Int?
  notes           String?
  status          BidStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  repairRequest RepairRequest @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairJob     RepairJob?

  @@unique([repairRequestId, shopId])
  @@index([repairRequestId])
  @@index([shopId])
}

model RepairJob {
  id                String          @id @default(cuid())
  repairRequestId   String          @unique
  shopId            String
  acceptedBidId     String?         @unique
  status            RepairJobStatus @default(CREATED)
  diagnosisNotes    String?
  finalQuotedAmount Float?
  customerApproved  Boolean?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  repairRequest  RepairRequest  @relation(fields: [repairRequestId], references: [id], onDelete: Cascade)
  shop           Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  acceptedBid    Bid?           @relation(fields: [acceptedBidId], references: [id])
  deliveries     Delivery[]
  warranty       Warranty?
  invoices       Invoice[]
  supportTickets SupportTicket[]

  @@index([shopId])
  @@index([status])
}

model RiderProfile {
  id                    String                        @id @default(cuid())
  userId                String                        @unique
  vehicleType           String?
  nidDocumentUrl        String?
  educationDocumentUrl  String?
  cvDocumentUrl         String?
  status                DeliveryAgentStatus          @default(OFFLINE)
  isActive              Boolean                       @default(true)
  registrationStatus    DeliveryPartnerApprovalStatus @default(APPROVED)
  currentLat            Float?
  currentLng            Float?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries    Delivery[]
  coverageZones RiderCoverage[]
  payoutRecords VendorPayout[] @relation("DeliveryAgentPayouts")

  @@index([status, isActive])
  @@index([registrationStatus])
}

model CoverageZone {
  id         String   @id @default(cuid())
  name       String
  city       String?
  area       String?
  postalCode String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  riders     RiderCoverage[]
  deliveries Delivery[]

  @@index([city, area])
}

model RiderCoverage {
  id             String   @id @default(cuid())
  riderProfileId String
  coverageZoneId String
  createdAt      DateTime @default(now())

  riderProfile RiderProfile @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  coverageZone CoverageZone @relation(fields: [coverageZoneId], references: [id], onDelete: Cascade)

  @@unique([riderProfileId, coverageZoneId])
}

model Delivery {
  id                 String            @id @default(cuid())
  repairJobId        String
  deliveryAgentId    String?
  coverageZoneId     String?
  direction          DeliveryDirection
  type               DeliveryType      @default(REGULAR)
  status             DeliveryStatus    @default(PENDING)
  partnerName        String?
  externalOrderId    String?
  trackingCode       String?
  riderName          String?
  riderPhone         String?
  pickupAddress      String
  dropAddress        String
  distanceKm         Float?
  fee                Float?
  scheduledAt        DateTime?
  dispatchedAt       DateTime?
  pickedUpAt         DateTime?
  deliveredAt        DateTime?
  cancellationReason String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  repairJob     RepairJob        @relation(fields: [repairJobId], references: [id], onDelete: Cascade)
  deliveryAgent RiderProfile?    @relation(fields: [deliveryAgentId], references: [id], onDelete: SetNull)
  coverageZone  CoverageZone?    @relation(fields: [coverageZoneId], references: [id], onDelete: SetNull)
  notifications NotificationLog[]
  chatMessages  DeliveryChatMessage[]

  @@index([repairJobId])
  @@index([status])
  @@index([deliveryAgentId])
}

model DeliveryChatMessage {
  id              String   @id @default(cuid())
  deliveryId      String
  senderUserId    String
  senderRole      UserRole
  recipientUserId String
  message         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, createdAt])
  @@index([senderUserId, recipientUserId, createdAt])
}

model VerificationRecord {
  id                  String                 @id @default(cuid())
  targetType          VerificationTargetType
  status              VerificationStatus     @default(PENDING)
  provider            VerificationProvider   @default(MANUAL)
  userId              String?
  vendorApplicationId String?                @unique
  shopId              String?
  reviewedByAdminId   String?
  subjectRef          String?
  providerReference   String?
  notes               String?
  requestedAt         DateTime               @default(now())
  resolvedAt          DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  user              User?              @relation("VerificationSubjectUser", fields: [userId], references: [id], onDelete: SetNull)
  vendorApplication VendorApplication? @relation(fields: [vendorApplicationId], references: [id], onDelete: Cascade)
  shop              Shop?              @relation(fields: [shopId], references: [id], onDelete: SetNull)
  reviewedByAdmin   User?              @relation("VerificationReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)

  @@index([status, provider])
  @@index([userId])
  @@index([shopId])
}

model Invoice {
  id               String        @id @default(cuid())
  repairRequestId  String?
  repairJobId      String?
  shopId           String?
  type             InvoiceType   @default(FINAL)
  status           InvoiceStatus @default(DRAFT)
  invoiceNumber    String        @unique
  subtotalAmount   Float         @default(0)
  deliveryAmount   Float         @default(0)
  discountAmount   Float         @default(0)
  commissionAmount Float         @default(0)
  totalAmount      Float         @default(0)
  issuedAt         DateTime?
  dueAt            DateTime?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  repairRequest RepairRequest?   @relation(fields: [repairRequestId], references: [id], onDelete: SetNull)
  repairJob     RepairJob?       @relation(fields: [repairJobId], references: [id], onDelete: SetNull)
  shop          Shop?            @relation(fields: [shopId], references: [id], onDelete: SetNull)
  lineItems     InvoiceLineItem[]
  payments      Payment[]
  ledgerEntries LedgerEntry[]

  @@index([repairRequestId])
  @@index([repairJobId])
  @@index([shopId])
  @@index([status])
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  shopServiceId String?
  title         String
  description   String?
  quantity      Int      @default(1)
  unitPrice     Float    @default(0)
  totalPrice    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shopService ShopService? @relation(fields: [shopServiceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([shopServiceId])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  repairRequestId String?
  invoiceId       String?
  amount          Float
  currency        String        @default("BDT")
  method          PaymentMethod?
  status          PaymentStatus @default(PENDING)
  transactionRef  String?       @unique
  gatewayResponse String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  repairRequest RepairRequest? @relation(fields: [repairRequestId], references: [id], onDelete: SetNull)
  invoice       Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  ledgerEntries LedgerEntry[]

  @@index([userId])
  @@index([repairRequestId])
  @@index([invoiceId])
  @@index([status])
}

model LedgerEntry {
  id          String          @id @default(cuid())
  shopId      String?
  paymentId   String?
  invoiceId   String?
  payoutId    String?
  type        LedgerEntryType
  direction   LedgerDirection
  amount      Float
  currency    String          @default("BDT")
  description String?
  effectiveAt DateTime        @default(now())
  createdAt   DateTime        @default(now())

  shop    Shop?         @relation(fields: [shopId], references: [id], onDelete: SetNull)
  payment Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  invoice Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  payout  VendorPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([payoutId])
  @@index([type, direction])
}

model VendorPayout {
  id             String       @id @default(cuid())
  shopId         String?
  riderProfileId String?
  amount         Float
  currency       String       @default("BDT")
  status         PayoutStatus @default(PENDING)
  reference      String?      @unique
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  shop          Shop?         @relation(fields: [shopId], references: [id], onDelete: SetNull)
  riderProfile  RiderProfile? @relation("DeliveryAgentPayouts", fields: [riderProfileId], references: [id], onDelete: SetNull)
  ledgerEntries LedgerEntry[]

  @@index([shopId])
  @@index([riderProfileId])
  @@index([status])
}

model Rating {
  id             String   @id @default(cuid())
  userId         String
  shopId         String
  score          Int
  review         String?
  isHidden       Boolean  @default(false)
  moderatedAt    DateTime?
  moderatedById  String?
  moderationNote String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User  @relation("RatingAuthor", fields: [userId], references: [id], onDelete: Cascade)
  shop        Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  moderatedBy User? @relation("RatingModerator", fields: [moderatedById], references: [id], onDelete: SetNull)

  @@unique([userId, shopId])
  @@index([shopId])
  @@index([moderatedById])
}

model Warranty {
  id           String   @id @default(cuid())
  repairJobId  String   @unique
  title        String
  details      String?
  durationDays Int
  startsAt     DateTime
  endsAt       DateTime
  createdAt    DateTime @default(now())

  repairJob RepairJob @relation(fields: [repairJobId], references: [id], onDelete: Cascade)
}

model RecentlyViewed {
  id       String   @id @default(cuid())
  userId   String
  shopId   String
  viewedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt])
  @@index([shopId])
}

model SupportTicket {
  id              String              @id @default(cuid())
  userId          String
  shopId          String?
  repairRequestId String?
  repairJobId     String?
  assigneeAdminId String?
  subject         String
  message         String
  status          SupportTicketStatus @default(OPEN)
  priority        String?
  adminNotes      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user          User           @relation("TicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  shop          Shop?          @relation(fields: [shopId], references: [id], onDelete: SetNull)
  repairRequest RepairRequest? @relation(fields: [repairRequestId], references: [id], onDelete: SetNull)
  repairJob     RepairJob?     @relation(fields: [repairJobId], references: [id], onDelete: SetNull)
  assigneeAdmin User?          @relation("TicketAssignee", fields: [assigneeAdminId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([shopId])
  @@index([repairRequestId])
  @@index([repairJobId])
  @@index([status])
}

model NotificationLog {
  id              String             @id @default(cuid())
  repairRequestId String?
  deliveryId      String?
  channel         NotificationChannel
  recipient       String
  subject         String?
  body            String
  provider        String?
  providerRef     String?
  status          NotificationStatus @default(QUEUED)
  sentAt          DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  repairRequest RepairRequest? @relation(fields: [repairRequestId], references: [id], onDelete: SetNull)
  delivery      Delivery?      @relation(fields: [deliveryId], references: [id], onDelete: SetNull)

  @@index([repairRequestId])
  @@index([deliveryId])
  @@index([channel, status])
}

model OfferBanner {
  id              String          @id @default(cuid())
  title           String
  subtitle        String?
  imageUrl        String?
  ctaLabel        String?
  ctaHref         String?
  backgroundColor String?
  isActive        Boolean         @default(true)
  position        Int             @default(0)
  sectionType     HomeSectionType @default(HERO_OFFER)
  startsAt        DateTime?
  endsAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([isActive, position])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  shopId    String
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop  Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId, status])
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  serviceName String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(1)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
}

model AiChatSession {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AiChatMessage[]
}

model AiChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  text      String
  createdAt DateTime @default(now())

  session   AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}